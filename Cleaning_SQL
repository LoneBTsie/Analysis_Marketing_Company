SELECT *
FROM dbo.customers;

SELECT *
FROM dbo.geography;

-- ************************************************* --
-- Join the dim_customers with dim_geography
SELECT c.CustomerID, c.CustomerName, c.Email, c.Gender, 
    c.Age, g.Country, g.City
FROM dbo.customers as c
LEFT JOIN dbo.geography as g
ON c.GeographyID = g.GeographyID;

